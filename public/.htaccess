# Serve index.html for directories that have it
DirectoryIndex index.html

# Avoid Options -Indexes here; some hosts (e.g. Hostinger) return 403 if .htaccess overrides Options

<IfModule mod_rewrite.c>
RewriteEngine On
RewriteBase /

# If the request is for a directory that has no index.html, serve path.html instead (Next.js static export)
RewriteCond %{REQUEST_FILENAME} -d
RewriteCond %{REQUEST_URI} ^/(.+?)/?$
RewriteCond %{DOCUMENT_ROOT}/%1.html -f
RewriteRule ^(.+?)/?$ $1.html [L]

# If the request is not a file or directory, try adding .html
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME}.html -f
RewriteRule ^(.*)$ $1.html [L]
</IfModule>

# Use our 404 page
ErrorDocument 404 /404.html
